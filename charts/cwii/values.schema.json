{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "cwii Helm values",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "logLevel": { "type": "string" },
    "mountRoot": { "type": "string", "pattern": "^/" },
    "tokenExpirationSeconds": { "type": "integer", "minimum": 600 },
    "otel": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" }
      }
    },
    "providers": {
      "type": "object",
      "properties": {
        "gcp": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "defaultAudience": { "type": "string" },
            "deliveryMode": { "type": "string", "enum": ["configMap", "initContainer"] },
            "initImage": { "type": "string" },
            "verifyImage": { "type": "string" }
          }
        },
        "aws": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "defaultAudience": { "type": "string" },
            "verifyImage": { "type": "string" }
          }
        },
        "az": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "defaultAudience": { "type": "string" },
            "verifyImage": { "type": "string" }
          }
        }
      }
    },
    "compat": {
      "type": "object",
      "properties": {
        "nativeAnnotations": { "type": "boolean" }
      }
    },
    "webhook": {
      "type": "object",
      "properties": {
        "failurePolicy": { "type": "string", "enum": ["Ignore", "Fail"] },
        "reinvocationPolicy": { "type": "string", "enum": ["Never", "IfNeeded"] },
        "matchPolicy": { "type": "string", "enum": ["Exact", "Equivalent"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 30 },
        "sideEffects": { "type": "string", "enum": ["None", "NoneOnDryRun"] },
        "namespaceSelector": {
          "type": "object",
          "properties": {
            "excludeNamespaces": { "type": "array", "items": { "type": "string" } },
            "matchLabels": { "type": "object" }
          }
        },
        "objectSelector": { "type": "object" },
        "matchConditions": { "type": "array" }
      }
    },
    "tls": {
      "type": "object",
      "properties": {
        "certManager": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "createIssuer": { "type": "boolean" },
            "issuer": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] }
              }
            },
            "duration": { "type": "string" },
            "renewBefore": { "type": "string" }
          }
        },
        "selfSigned": {
          "type": "object",
          "properties": {
            "durationDays": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer" },
        "targetPort": { "type": "integer" },
        "annotations": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "priorityClassName": { "type": "string" },
    "topologySpreadConstraints": { "type": "array" },
    "affinity": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    }
  }
}
